# Server
PORT=4000
NODE_ENV=development

# Database (SQLite for local, PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# Redis (optional for local, required for production caching)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-to-a-random-secret-in-production"
JWT_REFRESH_SECRET="change-me-to-another-random-secret"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# MinIO (S3-compatible storage, optional for local)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="clukstars-media"
MINIO_USE_SSL=false

# CORS
CORS_ORIGIN="http://localhost:5173"

# 2FA
APP_NAME="CLUKSTARS CMS"
