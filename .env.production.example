# Production Environment Configuration
# Copy this to .env.production and fill in your values

NODE_ENV=production
PORT=4000

# Database (SQLite for simplicity, PostgreSQL recommended for production)
DATABASE_URL=file:./backend/prisma/prod.db

# JWT Secrets - Generate strong random secrets!
# Use: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-min-64-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-64-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS - Lock to your production domain
CORS_ORIGIN=https://www.clukstars.com

# MinIO/S3 (Optional - for cloud storage)
# MINIO_ENDPOINT=
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=clukstars-media
# MINIO_USE_SSL=true

# Redis (Optional - for caching/sessions)
# REDIS_URL=redis://localhost:6379

# App Info
APP_NAME=CLUKSTARS CMS